# Throughput scenario with batched operations using KeyValue API
#
# Default data size: 1 KB records (10 fields, 100 bytes each, plus key)
# Batch size: 1000 records per operation
# Request distribution: sequential
# Threads per client: 16

workload=site.ycsb.workloads.CoreWorkload
db=site.ycsb.db.ignite3.IgniteClient

recordcount=100m
batchsize=1k
# 'warmupops' and 'operationcount' are batched operations,
# number of processed records evaluate as 'warmupops' * 'batchsize' and 'operationcount' * 'batchsize'
warmupops=25k
operationcount=300k

threadcount=16

readproportion=1
updateproportion=0
scanproportion=0
insertproportion=0

readallfields=true
dataintegrity=true
requestdistribution=sequential

status=true
status.interval=1
